# RxMax Backend — environment variables
#
# Copy this to .env (local dev) or set in Render dashboard (production).
# DO NOT commit .env to git — it should already be gitignored.

# ============================================================================
# REQUIRED — server will refuse to start in production without these.
# ============================================================================

NODE_ENV=production

# JWT signing secret. MUST be 32+ random characters. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Postgres — Render auto-injects DATABASE_URL when DB is attached via blueprint.
# For local dev, set the individual vars OR DATABASE_URL.
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rxmax

# Server port. Render sets this automatically (10000); local dev typically 3001.
PORT=3001

# ============================================================================
# OPTIONAL — feature gating
# ============================================================================

# Google Gemini — for AI prescription OCR. Without this, prescription upload
# falls back to demo mode with hardcoded sample medicines.
GEMINI_API_KEY=

# WhatsApp via Gupshup or Wati. Without WHATSAPP_API_KEY, messages are mocked
# (logged to console only). For production, sign up at gupshup.io or wati.io.
WHATSAPP_PROVIDER=gupshup
WHATSAPP_API_KEY=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Admin seed credentials (used by migrate.js when no admin exists)
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=
